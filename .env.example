# Supabase Postgres connection (provision via the Vercel Marketplace → Supabase,
# or from supabase.com → Project Settings → Database → Connection string).
#
# DATABASE_URL: the **pooled** connection (Transaction pooler, port 6543). Used
# by the app at runtime. The driver sets prepare:false for pgbouncer.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# DIRECT_URL: the **direct/session** connection (port 5432). Used by drizzle-kit
# for migrations/seed. Optional — falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Email digests (Resend) ----
# Create an API key at resend.com → API Keys. Required to send the weekly/
# biweekly/monthly finance digests; blank = sending is a no-op.
RESEND_API_KEY=""
# Sender + reply-to. The domain in EMAIL_FROM must be VERIFIED in Resend
# (Domains → add vectorux.com → add the DKIM/SPF DNS records). Until verified,
# Resend only delivers to your own account email.
EMAIL_FROM="Zitting HQ <finance@vectorux.com>"
EMAIL_REPLY_TO="jared@vectorux.com"
