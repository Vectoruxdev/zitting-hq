# Supabase Postgres connection (provision via the Vercel Marketplace → Supabase,
# or from supabase.com → Project Settings → Database → Connection string).
#
# DATABASE_URL: the **pooled** connection (Transaction pooler, port 6543). Used
# by the app at runtime. The driver sets prepare:false for pgbouncer.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# DIRECT_URL: the **direct/session** connection (port 5432). Used by drizzle-kit
# for migrations/seed. Optional — falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Email digests (Resend) ----
# Create an API key at resend.com → API Keys. Sends invite emails + finance
# digests; blank = sending is a no-op. Use a key from the Resend account where
# archaflow.com is verified (the EMAIL_FROM domain below).
RESEND_API_KEY=""
# Sender + reply-to. The domain in EMAIL_FROM must be VERIFIED in Resend.
# We default to archaflow.com (already verified). The RESEND_API_KEY above must
# belong to that same Resend account, or sends will be rejected.
EMAIL_FROM="Family HQ <noreply@archaflow.com>"
EMAIL_REPLY_TO="jared@vectorux.com"

# ---- MCP server (connect Zitting HQ to Claude) ----
# Two shared secrets guard the remote MCP endpoint at /api/mcp. Generate long
# random values (e.g. `openssl rand -hex 32`) and set the SAME value in Claude's
# connector config (Authorization: Bearer <token>, or ?key=<token> on the URL).
# The token has FULL OWNER authority over the entire household's finances —
# no per-member scoping. If neither is set, the endpoint is closed (returns 503).
#
# MCP_TOKEN          = full READ + WRITE (incl. irreversible ops, which require confirm:true)
# MCP_READONLY_TOKEN = READ-only (write tools are not registered for this token)
MCP_TOKEN=""
MCP_READONLY_TOKEN=""

# ---- Nest cameras → Govee lights (owner-only module) ----
# OAuth client from the Google CLOUD project (console.cloud.google.com →
# APIs & Services → Credentials). The client ID is public-ish; the SECRET is
# sensitive — env vars only, never committed.
GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET
# Device Access project UUID from console.nest.google.com/device-access —
# NOT the Cloud project id (two different consoles).
NEST_PROJECT_ID
# Shared secret guarding the Pub/Sub push endpoint /api/nest/events
# (`openssl rand -hex 32`). Put the SAME value in the push subscription URL:
#   https://<domain>/api/nest/events?key=<token>
# Unset = endpoint closed (503).
NEST_EVENTS_TOKEN
# Govee Home app → Profile → Settings → Apply for API Key (arrives by email).
GOVEE_API_KEY
# Local dev only: set to http://localhost:3000 so the OAuth redirect matches
# the localhost redirect URI registered in Google Cloud.
# NEXT_PUBLIC_SITE_URL
