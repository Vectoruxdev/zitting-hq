# Supabase Postgres connection (provision via the Vercel Marketplace → Supabase,
# or from supabase.com → Project Settings → Database → Connection string).
#
# DATABASE_URL: the **pooled** connection (Transaction pooler, port 6543). Used
# by the app at runtime. The driver sets prepare:false for pgbouncer.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# DIRECT_URL: the **direct/session** connection (port 5432). Used by drizzle-kit
# for migrations/seed. Optional — falls back to DATABASE_URL if unset.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ---- Email digests (Resend) ----
# Create an API key at resend.com → API Keys. Sends invite emails + finance
# digests; blank = sending is a no-op. Use a key from the Resend account where
# archaflow.com is verified (the EMAIL_FROM domain below).
RESEND_API_KEY=""
# Sender + reply-to. The domain in EMAIL_FROM must be VERIFIED in Resend.
# We default to archaflow.com (already verified). The RESEND_API_KEY above must
# belong to that same Resend account, or sends will be rejected.
EMAIL_FROM="Family HQ <noreply@archaflow.com>"
EMAIL_REPLY_TO="jared@vectorux.com"

# ---- MCP server (connect Zitting HQ to Claude) ----
# Shared secret guarding the remote MCP endpoint at /api/mcp. Generate a long
# random value (e.g. `openssl rand -hex 32`) and set the SAME value in Claude's
# connector config (Authorization: Bearer <token>, or ?key=<token> on the URL).
# If unset, the MCP endpoint is closed (returns 503).
MCP_TOKEN=""
